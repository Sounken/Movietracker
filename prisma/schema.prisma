generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String              @id @default(cuid())
  name           String?
  email          String              @unique
  passwordHash   String
  avatarUrl      String?
  bannerUrl      String?
  bio            String?
  createdAt      DateTime            @default(now())
  films          UserFilm[]
  favoriteFilms  UserFavoriteFilm[]
}

model UserFavoriteFilm {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tmdbId   Int
  position Int

  @@unique([userId, position])
  @@unique([userId, tmdbId])
}

model UserFilm {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tmdbId    Int
  rating    Float?
  review    String?
  watchlist Boolean   @default(false)
  liked     Boolean   @default(false)
  watched   Boolean   @default(false)
  watchedAt DateTime?
  runtime   Int?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([userId, tmdbId])
}
